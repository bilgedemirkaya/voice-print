# ElevenLabs API key — read ONLY by the MCP server (mcp-server/).
# Never exposed to the browser. See CLAUDE.md §6, §10.
ELEVENLABS_API_KEY=

# Directory where the MCP server writes converted audio.
# The Next.js /api/audio/[handle] route serves files from here. See CLAUDE.md §4.
AUDIO_TMP_DIR=./.tmp/audio

# Secret used by the Next.js app to sign the free-trial counter cookie.
# Set a long random value in production; falls back to a dev default if unset. See lib/trial.ts.
TRIAL_COOKIE_SECRET=

# Shared access code that unlocks unlimited transforms on the host's key for friends (like a
# discount code). Set your own secret value here — if unset, no code unlocks (BYOK + trial still
# work). Local dev (next dev) is always unlimited regardless. See lib/access.ts.
ACCESS_CODE=

# Optional per-IP backstop (survives cookie-clearing) via Upstash Redis REST.
# Leave blank to disable (cookie-only). Create a free DB at https://console.upstash.com. See lib/trialIp.ts.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Max free transforms per IP per day before requiring a personal key (default 10).
TRIAL_IP_DAILY_CAP=


