# ElevenLabs API key — required by list_voices / get_voice_settings / transform_voice.
# Create one at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Optional. Directory where converted audio is written and served from.
# Absolute path recommended. Defaults to <os-tmp>/voicescreen-audio when unset.
AUDIO_TMP_DIR=
